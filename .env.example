# Tipovačka 2.0 — Go version
# Zkopíruj jako .env a vyplň hodnoty

# Databáze (stejná Neon DB jako Python verze)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Bezpečnost
SECRET_KEY=nahrad-nahodnym-retezcem-min-32-znaku

# Admin účet (vytvoří se při prvním startu)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=silne-heslo

# URL aplikace
APP_URL=https://tvoje-app.koyeb.app

# Port (Koyeb nastaví automaticky)
PORT=8080
